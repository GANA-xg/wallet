# ─── API Server ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Required: JWT signing secret (generate with: openssl rand -hex 32)
JWT_SECRET=dev-jwt-secret-do-not-use-in-prod

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# Database (if using PostgreSQL via Drizzle)
DATABASE_URL=postgresql://localhost:5432/vault

# ─── AI / LLM  ──────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# AI Provider ("local" uses built-in analyzer, no API key needed)
# Change to "openai", "gemini", or "claude" to use LLM-enhanced insights
AI_PROVIDER=local

# ─── Dev / Security ─────────────────────────────────────────
# Development-only OTP override (default: "000000" in dev mode)
DEV_OTP=000000

# OTP rate limiting (disabled by default in development, 5/min in production)
# Set to "0" to disable, or any positive integer for max requests per window
OTP_RATE_LIMIT_MAX=
# Rate limit time window in milliseconds (default: 60000 = 1 minute)
OTP_RATE_LIMIT_WINDOW_MS=60000

# ─── Mobile App (Expo) ──────────────────────────────────────
# Set this to the API server URL for production builds
EXPO_PUBLIC_API_URL=http://localhost:3001

# ─── Web App (Mockup Sandbox / Vite) ────────────────────────
VITE_API_URL=http://localhost:3001
